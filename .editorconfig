root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{R,r}]
indent_style = space
indent_size = 2

[*.{h,cpp}]
indent_style = space
indent_size = 4

[*.{Rmd,md}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[Makevars*]
indent_style = tab
